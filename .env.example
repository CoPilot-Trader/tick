# TICK Platform - Environment Variables
# Copy this file to .env and fill in your values

# === News API Keys (required for live news) ===
FINNHUB_API_KEY=your_finnhub_api_key
NEWSAPI_KEY=your_newsapi_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# === Market Data API Keys ===
TIINGO_API_KEY=your_tiingo_key
FMP_API_KEY=your_fmp_key

# === LLM Sentiment Analysis (optional - falls back to mock if not set) ===
OPENAI_API_KEY=your_openai_api_key

# === Database (production) ===
POSTGRES_USER=tick_user
POSTGRES_PASSWORD=tick_password
POSTGRES_DB=tick_db

# === Frontend ===
# Set to your server's public URL for production deployment
NEXT_PUBLIC_API_URL=http://localhost:8000
